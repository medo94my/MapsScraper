# Runtime configuration
# Copy this file to .env and export values in your shell before running.

# Prompt worker concurrency (minimum 1)
SCRAPER_MAX_CONCURRENCY=4

# Browser mode. Set to 0 for headed debugging runs.
SCRAPER_HEADLESS=0

# Progress display toggle for run() when show_progress is not passed.
SCRAPER_SHOW_PROGRESS=1

# Enable implicit checkpoint persistence when run() is called without
# an explicit Checkpoint instance.
SCRAPER_CHECKPOINT_ENABLED=1

# Output path used by implicit checkpoint mode.
SCRAPER_CHECKPOINT_PATH=output.jsonl
